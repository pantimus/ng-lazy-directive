{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ng-lazy-directive": {
      "projectType": "library",
      "root": "projects/ng-lazy-directive",
      "sourceRoot": "projects/ng-lazy-directive/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ng-lazy-directive/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ng-lazy-directive/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ng-lazy-directive/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/ng-lazy-directive/tsconfig.spec.json",
            "polyfills": ["zone.js", "zone.js/testing"]
          }
        }
      }
    },
    "demo-lazy": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/demo-lazy",
      "sourceRoot": "projects/demo-lazy/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/demo-lazy",
            "index": "projects/demo-lazy/src/index.html",
            "browser": "projects/demo-lazy/src/main.ts",
            "polyfills": ["zone.js"],
            "preserveSymlinks": true,
            "tsConfig": "projects/demo-lazy/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo-lazy/public"
              }
            ],
            "styles": ["projects/demo-lazy/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "prebundle": {
              "exclude": ["ng-lazy-directive"]
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "demo-lazy:build:production"
            },
            "development": {
              "buildTarget": "demo-lazy:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "projects/demo-lazy/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo-lazy/public"
              }
            ],
            "styles": ["projects/demo-lazy/src/styles.scss"],
            "scripts": []
          }
        }
      }
    }
  }
}
